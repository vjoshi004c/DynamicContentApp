@* @model HomeViewModel *@
@* @model dynamic *@

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DynamicContentApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DynamicContentApp.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="container">
        <main role="main" class="pb-3">
            <h2>Page Item content details on Master layout</h2>
            <h3>Title - @Model.Title</h3>
            <h3>ArticleShortDescription - @Model.ArticleShortDescription</h3>
          
            [[PLACEHOLDER_HEADER]]
        </main>
    </div>
   
    <div class="container">
        <main role="main" class="pb-3">
@*             @RenderBody() *@
            [[PLACEHOLDER_CONTENTBODY]]
        </main>
    </div>
    <div class="container">
        <main role="main" class="pb-3">
            [[PLACEHOLDER_FOOTER]]
        </main>
    </div>
   
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
@*     @await RenderSectionAsync("Scripts", required: false) *@
</body>
</html>
