        function removefromcontextmenu(element) {
            //alert('remove event');
            element.removeEventListener("contextmenu", function (e) {
                e.preventDefault();
                contextMenu.style.display = "none";
            });
        };

        function setupcontextmenu(element) {
            //alert(element.getAttribute('tag'));
            element.addEventListener("contextmenu", function (e) {
                e.preventDefault(); // Prevent default browser menu
                const currenttag = e.target.getAttribute('tag');
                //alert(currenttag);
                 const curid = e.target.getAttribute('id');
                 //alert(curid);
                //alert(currenttag);

                // Position menu at mouse location
                contextMenu.style.top = `${e.clientY}px`;
                contextMenu.style.left = `${e.clientX}px`;
                contextMenu.style.display = "block";
                const listItems = contextMenu.querySelectorAll('ul li');
                listItems.forEach((li, index) => {

                    li.setAttribute('itemid', currenttag);
                    li.addEventListener("click", function (e) {
                        e.preventDefault(); // Prevent default browser menu

                       const currentitemid = e.target.getAttribute('itemid');
                        //const currentitemid = e.target.getAttribute('id');
                       // alert(currentitemid);
                        const currentid = e.target.getAttribute('id');
                        if (currentid == 'edit_li') {
                            editdiv.style.display = "block";
                            const innerElement = editdiv.querySelector('h2 span');
                            innerElement.innerHTML = currentitemid;

                            //editdiv.innerHTML ="<h2>Edit selected item - <span>"+ currentitemid +" </span></h2>";
                            removediv.style.display = "none";
                            duplicatediv.style.display = "none";

                            //alert('inside div - ' + currentid +' and item id -'+ currentitemid);
                        }
                        if (currentid == 'remove_li') {
                            editdiv.style.display = "none";
                            removediv.style.display = "block";
                            duplicatediv.style.display = "none";
                            const innerElement = removediv.querySelector('h2 span');
                            innerElement.innerHTML = currentitemid;


                            //alert('inside div -' + currentid +' and item id -'+ currentitemid);

                        }
                        if (currentid == 'duplicate_li') {
                            editdiv.style.display = "none";
                            removediv.style.display = "none";
                            duplicatediv.style.display = "block";
                            const innerElement = duplicatediv.querySelector('h2 span');
                            innerElement.innerHTML = currentitemid;



                            //alert('inside div -' + currentid +' and item id -'+ currentitemid);

                        }


                    });

                });
            });



        }


    </script>
    <script>


        // Show custom menu on right-click
        document.addEventListener("contextmenu1", function (e) {
            e.preventDefault(); // Prevent default browser menu

            // Position menu at mouse location
            contextMenu.style.top = `${e.clientY}px`;
            contextMenu.style.left = `${e.clientX}px`;
            contextMenu.style.display = "block";
        });

        // Hide menu on click elsewhere
        document.addEventListener("click", function () {
            contextMenu.style.display = "none";
        });

        // Prevent menu from going off-screen
        window.addEventListener("resize", () => {
            contextMenu.style.display = "none";
        });
    </script>

    

